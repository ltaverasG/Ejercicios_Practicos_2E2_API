{
  "name": "challenge-automatizacion-demoblaze",
  "version": "1.0.0",
  "description": "Challenge de automatizacion QA: E2E (Playwright) y API (Playwright, Cypress) sobre demoblaze.com",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "test:api": "playwright test tests/api",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "cy:open": "cypress open --project cypress-example",
    "cy:run": "cypress run --project cypress-example"
  },
  "keywords": ["playwright", "typescript", "e2e", "api-testing", "demoblaze"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "cypress": "^13.15.0"
  }
}
